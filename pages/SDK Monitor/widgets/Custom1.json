    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>AI Telemetry — Event Dashboard</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: 'Segoe UI', system-ui, sans-serif;\n      background: #ffffff;\n      color: #1f2328;\n      min-height: 100vh;\n    }\n\n    /* ── Header ─────────────────────────────────────────── */\n    header {\n      background: #f6f8fa;\n      border-bottom: 1px solid #d0d7de;\n      padding: 16px 28px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 16px;\n      flex-wrap: wrap;\n    }\n    header h1 {\n      font-size: 1.15rem;\n      font-weight: 600;\n      color: #1f2328;\n      display: flex;\n      align-items: center;\n      gap: 10px;\n    }\n    header h1 .dot {\n      width: 10px; height: 10px;\n      border-radius: 50%;\n      background: #1a7f37;\n      display: inline-block;\n      animation: pulse 2s infinite;\n    }\n    @keyframes pulse {\n      0%, 100% { opacity: 1; }\n      50%       { opacity: 0.4; }\n    }\n    .stats {\n      display: flex;\n      gap: 20px;\n      flex-wrap: wrap;\n    }\n    .stat {\n      text-align: center;\n    }\n    .stat .val {\n      font-size: 1.4rem;\n      font-weight: 700;\n      color: #1f2328;\n    }\n    .stat .lbl {\n      font-size: 0.7rem;\n      color: #656d76;\n      text-transform: uppercase;\n      letter-spacing: .05em;\n    }\n\n    /* ── Filters ─────────────────────────────────────────── */\n    .toolbar {\n      background: #f6f8fa;\n      border-bottom: 1px solid #d0d7de;\n      padding: 12px 28px;\n      display: flex;\n      gap: 12px;\n      flex-wrap: wrap;\n      align-items: center;\n    }\n    .toolbar select, .toolbar input {\n      background: #ffffff;\n      border: 1px solid #d0d7de;\n      border-radius: 6px;\n      color: #1f2328;\n      padding: 6px 10px;\n      font-size: 0.82rem;\n      outline: none;\n    }\n    .toolbar select:focus, .toolbar input:focus {\n      border-color: #0969da;\n      box-shadow: 0 0 0 3px rgba(9,105,218,.12);\n    }\n    .toolbar label {\n      font-size: 0.8rem;\n      color: #656d76;\n    }\n    .toolbar .spacer { flex: 1; }\n    .refresh-badge {\n      font-size: 0.75rem;\n      color: #656d76;\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n    .refresh-badge input[type=checkbox] { accent-color: #1a7f37; }\n\n    /* ── Table ───────────────────────────────────────────── */\n    .table-wrap {\n      overflow-x: auto;\n      padding: 20px 28px;\n    }\n    table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 0.82rem;\n    }\n    thead th {\n      text-align: left;\n      padding: 8px 10px;\n      color: #656d76;\n      font-weight: 600;\n      font-size: 0.73rem;\n      text-transform: uppercase;\n      letter-spacing: .06em;\n      border-bottom: 1px solid #d0d7de;\n      white-space: nowrap;\n    }\n    tbody tr {\n      border-bottom: 1px solid #eaeef2;\n      cursor: pointer;\n      transition: background .12s;\n    }\n    tbody tr:hover { background: #f6f8fa; }\n    tbody tr.expanded { background: #f6f8fa; }\n    td {\n      padding: 9px 10px;\n      vertical-align: top;\n      max-width: 260px;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      white-space: nowrap;\n    }\n    td.wrap { white-space: normal; word-break: break-word; }\n\n    /* ── Detail panel ────────────────────────────────────── */\n    .detail-row td {\n      padding: 0;\n      background: #f6f8fa;\n    }\n    .detail-box {\n      padding: 16px 20px;\n      border-top: 1px solid #d0d7de;\n      border-bottom: 1px solid #d0d7de;\n    }\n    .detail-box pre {\n      font-size: 0.78rem;\n      color: #1f2328;\n      overflow-x: auto;\n      white-space: pre-wrap;\n      word-break: break-word;\n      max-height: 320px;\n      overflow-y: auto;\n    }\n\n    /* ── Badges ──────────────────────────────────────────── */\n    .badge {\n      display: inline-block;\n      padding: 2px 8px;\n      border-radius: 20px;\n      font-size: 0.72rem;\n      font-weight: 600;\n      white-space: nowrap;\n    }\n    .badge-human    { background: #dafbe1; color: #116329; }\n    .badge-automated{ background: #ffebe9; color: #a40e26; }\n    .badge-agent    { background: #fff8c5; color: #7d4e00; }\n    .badge-unknown  { background: #f0f0f0; color: #656d76; }\n    .badge-llm      { background: #ddf4ff; color: #0550ae; }\n    .badge-tool     { background: #fbefff; color: #622cbc; }\n    .badge-error    { background: #ffebe9; color: #a40e26; }\n\n    .alert-pill {\n      display: inline-block;\n      padding: 1px 7px;\n      border-radius: 4px;\n      font-size: 0.68rem;\n      font-weight: 600;\n      margin: 1px 2px;\n      background: #fff8c5;\n      color: #7d4e00;\n      border: 1px solid #e3c000;\n    }\n    .alert-pill.critical {\n      background: #ffebe9;\n      color: #a40e26;\n      border-color: #f5a8a8;\n    }\n\n    .signal-pill {\n      display: inline-block;\n      padding: 1px 6px;\n      border-radius: 4px;\n      font-size: 0.65rem;\n      background: #f0f0f0;\n      color: #656d76;\n      border: 1px solid #d0d7de;\n      margin: 1px 2px;\n    }\n\n    /* ── Empty state ─────────────────────────────────────── */\n    .empty {\n      text-align: center;\n      padding: 60px 20px;\n      color: #656d76;\n    }\n    .empty p { margin-top: 8px; font-size: 0.85rem; }\n  </style>\n</head>\n<body>\n\n<header>\n  <h1><span class=\"dot\"></span> AI Telemetry — Event Dashboard</h1>\n  <div class=\"stats\">\n    <div class=\"stat\"><div class=\"val\" id=\"st-total\">—</div><div class=\"lbl\">Events</div></div>\n    <div class=\"stat\"><div class=\"val\" id=\"st-human\"  style=\"color:#3fb950\">—</div><div class=\"lbl\">Human</div></div>\n    <div class=\"stat\"><div class=\"val\" id=\"st-auto\"   style=\"color:#f85149\">—</div><div class=\"lbl\">Automated</div></div>\n    <div class=\"stat\"><div class=\"val\" id=\"st-agent\"  style=\"color:#d29922\">—</div><div class=\"lbl\">Agent</div></div>\n    <div class=\"stat\"><div class=\"val\" id=\"st-alerts\" style=\"color:#d29922\">—</div><div class=\"lbl\">Alerts</div></div>\n  </div>\n</header>\n\n<div class=\"toolbar\">\n  <label>Entity\n    <select id=\"f-entity\" onchange=\"applyFilters()\">\n      <option value=\"\">All</option>\n      <option value=\"HUMAN\">HUMAN</option>\n      <option value=\"AUTOMATED\">AUTOMATED</option>\n      <option value=\"AGENT\">AGENT</option>\n      <option value=\"UNKNOWN\">UNKNOWN</option>\n    </select>\n  </label>\n  <label>Event type\n    <select id=\"f-type\" onchange=\"applyFilters()\">\n      <option value=\"\">All</option>\n      <option value=\"user_message\">user_message</option>\n      <option value=\"llm_call\">llm_call</option>\n      <option value=\"tool_call\">tool_call</option>\n      <option value=\"error\">error</option>\n    </select>\n  </label>\n  <label>Alert\n    <select id=\"f-alert\" onchange=\"applyFilters()\">\n      <option value=\"\">All</option>\n      <option value=\"DRIFT_ALERT\">DRIFT_ALERT</option>\n      <option value=\"TAKEOVER_ALERT\">TAKEOVER_ALERT</option>\n      <option value=\"ROLE_PLAY_INJECTION\">ROLE_PLAY_INJECTION</option>\n      <option value=\"PROGRESSIVE_PROBE\">PROGRESSIVE_PROBE</option>\n      <option value=\"REGULATORY_PROBE\">REGULATORY_PROBE</option>\n    </select>\n  </label>\n  <label>Search\n    <input type=\"text\" id=\"f-search\" placeholder=\"user_id, model, signal…\" oninput=\"applyFilters()\" style=\"width:180px\"/>\n  </label>\n  <div class=\"spacer\"></div>\n  <div class=\"refresh-badge\">\n    <input type=\"checkbox\" id=\"auto-refresh\" checked onchange=\"toggleAutoRefresh()\" />\n    <label for=\"auto-refresh\">Auto-refresh 5 s</label>\n  </div>\n</div>\n\n<div class=\"table-wrap\">\n  <table id=\"events-table\">\n    <thead>\n      <tr>\n        <th>Time</th>\n        <th>Type</th>\n        <th>User</th>\n        <th>Entity</th>\n        <th>Model</th>\n        <th>Latency</th>\n        <th>Tokens</th>\n        <th>Turn</th>\n        <th>Signals</th>\n        <th>Alerts</th>\n      </tr>\n    </thead>\n    <tbody id=\"events-body\">\n      <tr><td colspan=\"10\" class=\"empty\">Loading…</td></tr>\n    </tbody>\n  </table>\n</div>\n\n<script>\n  let allEvents  = [];\n  let refreshTimer = null;\n  let expandedId = null;\n\n  // ── Fetch ──────────────────────────────────────────────────────────────\n  async function fetchEvents() {\n    const params = new URLSearchParams({ limit: 500 });\n    try {\n      const res  = await fetch('/api/events?' + params);\n      const data = await res.json();\n      allEvents  = data.events || [];\n      updateStats();\n      applyFilters();\n    } catch (e) {\n      console.error('Fetch failed', e);\n    }\n  }\n\n  // ── Stats ──────────────────────────────────────────────────────────────\n  function updateStats() {\n    const human  = allEvents.filter(e => e.entity_type === 'HUMAN').length;\n    const auto   = allEvents.filter(e => e.entity_type === 'AUTOMATED').length;\n    const agent  = allEvents.filter(e => e.entity_type === 'AGENT').length;\n    const alerts = allEvents.filter(e => e.behavioral_alerts).length;\n    document.getElementById('st-total').textContent = allEvents.length;\n    document.getElementById('st-human').textContent  = human;\n    document.getElementById('st-auto').textContent   = auto;\n    document.getElementById('st-agent').textContent  = agent;\n    document.getElementById('st-alerts').textContent = alerts;\n  }\n\n  // ── Filters ────────────────────────────────────────────────────────────\n  function applyFilters() {\n    const fEntity = document.getElementById('f-entity').value;\n    const fType   = document.getElementById('f-type').value;\n    const fAlert  = document.getElementById('f-alert').value;\n    const fSearch = document.getElementById('f-search').value.toLowerCase();\n\n    let filtered = allEvents.filter(e => {\n      if (fEntity && e.entity_type !== fEntity) return false;\n      if (fType   && e.event_type  !== fType)   return false;\n      if (fAlert  && !(e.behavioral_alerts || '').includes(fAlert)) return false;\n      if (fSearch) {\n        const hay = JSON.stringify(e).toLowerCase();\n        if (!hay.includes(fSearch)) return false;\n      }\n      return true;\n    });\n\n    renderTable(filtered);\n  }\n\n  // ── Render ─────────────────────────────────────────────────────────────\n  function entityBadge(t) {\n    const map = {\n      HUMAN:     'badge-human',\n      AUTOMATED: 'badge-automated',\n      AGENT:     'badge-agent',\n      UNKNOWN:   'badge-unknown',\n    };\n    const cls = map[t] || 'badge-unknown';\n    return `<span class=\"badge ${cls}\">${t || '—'}</span>`;\n  }\n\n  function eventBadge(t) {\n    const map = { llm_call: 'badge-llm', tool_call: 'badge-tool', error: 'badge-error' };\n    return `<span class=\"badge ${map[t] || 'badge-unknown'}\">${t || '—'}</span>`;\n  }\n\n  const CRITICAL_ALERTS = new Set(['REGULATORY_PROBE', 'PROGRESSIVE_PROBE', 'TAKEOVER_ALERT']);\n\n  function alertPills(raw) {\n    if (!raw) return '—';\n    return raw.split('|').map(a =>\n      `<span class=\"alert-pill${CRITICAL_ALERTS.has(a) ? ' critical' : ''}\">${a}</span>`\n    ).join('');\n  }\n\n  function signalPills(raw) {\n    if (!raw) return '—';\n    return raw.split('|').map(s =>\n      `<span class=\"signal-pill\">${s}</span>`\n    ).join('');\n  }\n\n  function fmtTime(iso) {\n    if (!iso) return '—';\n    return iso.replace('T', ' ').replace('Z', '');\n  }\n\n  function renderTable(events) {\n    const tbody = document.getElementById('events-body');\n    if (!events.length) {\n      tbody.innerHTML = `<tr><td colspan=\"10\"><div class=\"empty\">\n        <strong>No events match the current filters.</strong>\n        <p>Send a message to the chatbot at <a href=\"/\" style=\"color:#58a6ff\">/</a> to generate events.</p>\n      </div></td></tr>`;\n      return;\n    }\n\n    tbody.innerHTML = events.map(e => {\n      const id = e.event_id || Math.random();\n      return `\n      <tr onclick=\"toggleDetail('${id}')\" data-id=\"${id}\">\n        <td>${fmtTime(e.timestamp_iso)}</td>\n        <td>${eventBadge(e.event_type)}</td>\n        <td title=\"${e.email || ''}\">${(e.user_id || '—').substring(0,14)}</td>\n        <td>${entityBadge(e.entity_type)}${e.entity_subtype ? `<br/><span style=\"font-size:.65rem;color:#8b949e\">${e.entity_subtype}</span>` : ''}</td>\n        <td title=\"${e.model || ''}\">${(e.model || '—').replace('claude-','c-').replace('gpt-','g-')}</td>\n        <td>${e.latency_ms != null ? e.latency_ms + ' ms' : '—'}</td>\n        <td>${e.total_tokens != null ? e.total_tokens : '—'}</td>\n        <td style=\"text-align:center\">${e.session_turn_index != null ? e.session_turn_index : '—'}</td>\n        <td class=\"wrap\">${signalPills(e.classification_signals)}</td>\n        <td class=\"wrap\">${alertPills(e.behavioral_alerts)}</td>\n      </tr>\n      <tr class=\"detail-row\" id=\"detail-${id}\" style=\"display:none\">\n        <td colspan=\"10\">\n          <div class=\"detail-box\">\n            <pre>${JSON.stringify(e, null, 2)}</pre>\n          </div>\n        </td>\n      </tr>`;\n    }).join('');\n  }\n\n  // ── Expand / collapse row ─────────────────────────────────────────────\n  function toggleDetail(id) {\n    if (expandedId && expandedId !== id) {\n      const prev = document.getElementById('detail-' + expandedId);\n      if (prev) prev.style.display = 'none';\n    }\n    const row = document.getElementById('detail-' + id);\n    if (!row) return;\n    const visible = row.style.display !== 'none';\n    row.style.display = visible ? 'none' : 'table-row';\n    expandedId = visible ? null : id;\n  }\n\n  // ── Auto-refresh ──────────────────────────────────────────────────────\n  function toggleAutoRefresh() {\n    if (document.getElementById('auto-refresh').checked) {\n      startRefresh();\n    } else {\n      clearInterval(refreshTimer);\n    }\n  }\n\n  function startRefresh() {\n    clearInterval(refreshTimer);\n    refreshTimer = setInterval(fetchEvents, 5000);\n  }\n\n  // ── Init ──────────────────────────────────────────────────────────────\n  fetchEvents();\n  startRefresh();\n</script>\n</body>\n</html>",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
  "version": 1,
  "widgetId": "7b5yrasctg",
  "widgetName": "Custom1"
}