    "css": "",
    "html": "<div id=\"root\"><div class=\"ld\">Waiting for scan data…</div></div>\n<style>\n  :root{\n    --ink:#0f172a;--muted:#64748b;--faint:#94a3b8;--line:#e8edf3;\n    --panel:#fff;--soft:#f8fafc;--accent:#4f46e5;\n    --bar:#6366f1;--bar2:#818cf8;--saas:#0891b2;--saas-bg:#ecfeff;--off:#94a3b8;--ok:#16a34a;\n    --high:#ea580c;--high-bg:#fff7ed;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .ld{padding:28px;color:var(--faint);font-size:13px}\n  .wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;\n    padding:20px 22px;box-shadow:0 1px 2px rgba(15,23,42,.04)}\n  .acthead{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:4px}\n  .actname{font-size:18px;font-weight:700;letter-spacing:-.01em}\n  .actsub{font-size:12.5px;color:var(--muted);line-height:1.5;margin:6px 0 18px;\n    padding-left:11px;border-left:3px solid var(--accent)}\n  .actsub b{color:var(--ink)}\n  .strip{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:22px}\n  .stat{border:1px solid var(--line);border-radius:11px;padding:13px 14px;background:var(--soft)}\n  .stat .v{font-size:26px;font-weight:800;letter-spacing:-.02em;line-height:1}\n  .stat .l{font-size:11px;color:var(--muted);margin-top:5px;line-height:1.3}\n  .stat.em .v{color:var(--accent)}\n  .pblock{margin-bottom:20px}\n  .ptitle{font-size:13px;font-weight:700;margin-bottom:2px}\n  .pcap{font-size:11px;color:var(--faint);margin-bottom:11px}\n  .cols{display:grid;grid-template-columns:1fr 1fr;gap:26px}\n  @media(max-width:720px){.cols{grid-template-columns:1fr}.strip{grid-template-columns:repeat(3,1fr)}}\n  .row{display:grid;grid-template-columns:120px 1fr 38px;align-items:center;gap:9px;margin:5px 0}\n  .row .nm{font-size:12px;color:var(--ink);font-family:var(--mono);text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n  .row .track{height:16px;background:#eef1f6;border-radius:5px;overflow:hidden}\n  .row .fill{height:100%;background:linear-gradient(90deg,var(--bar),var(--bar2));border-radius:5px}\n  .row .ct{font-size:12px;font-weight:700;text-align:right;color:var(--ink)}\n  .saasbadge{display:inline-block;font-size:9px;font-weight:700;color:var(--saas);background:var(--saas-bg);\n    border:1px solid #a5f3fc;border-radius:4px;padding:0 4px;margin-left:5px;vertical-align:middle}\n  .more{font-size:11px;color:var(--faint);margin-top:7px;padding-left:2px}\n  .hot{border:1px solid var(--line);border-radius:11px;padding:14px 16px;background:var(--soft)}\n  .hotrepo{margin:10px 0}.hotrepo:first-child{margin-top:0}\n  .hr-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px}\n  .hr-name{font-size:13px;font-weight:700;font-family:var(--mono)}\n  .hr-ct{font-size:12px;color:var(--muted)}.hr-ct b{color:var(--ink);font-weight:700}\n  .hr-track{height:9px;background:#eef1f6;border-radius:5px;overflow:hidden}\n  .hr-fill{height:100%;background:linear-gradient(90deg,#4f46e5,#818cf8);border-radius:5px}\n  .hr-dir{font-size:11px;color:var(--faint);margin-top:4px}\n  .hr-dir code{font-family:var(--mono);color:var(--muted)}\n  /* HF credential panel */\n  .cred{border:1px solid #fed7aa;border-radius:12px;background:var(--high-bg);padding:14px 16px}\n  .cred-top{display:flex;gap:16px;flex-wrap:wrap;align-items:center}\n  .cred-stat{text-align:center;padding:4px 14px 4px 0}\n  .cred-stat .v{font-size:26px;font-weight:800;line-height:1;color:var(--high)}\n  .cred-stat.muted .v{color:var(--muted)}\n  .cred-stat .l{font-size:10.5px;color:var(--muted);margin-top:4px;text-transform:uppercase;letter-spacing:.04em;font-weight:700}\n  .cred-div{width:1px;align-self:stretch;background:#fcd34d;margin:2px 0}\n  .cred-by{flex:1 1 240px}\n  .cred-by .lab{font-size:10.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;font-weight:700;margin-bottom:8px}\n  .cred-row{display:grid;grid-template-columns:150px 1fr 34px;align-items:center;gap:9px;margin:4px 0}\n  .cred-row .rn{font-size:12px;font-family:var(--mono);text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--ink)}\n  .cred-row .tr{height:13px;background:#fde9d3;border-radius:4px;overflow:hidden}\n  .cred-row .fl{height:100%;background:linear-gradient(90deg,#ea580c,#fb923c);border-radius:4px}\n  .cred-row .cc{font-size:12px;font-weight:700;text-align:right}\n  .cred-note{font-size:11.5px;color:var(--muted);line-height:1.5;margin-top:11px;padding-top:11px;border-top:1px dashed #fcd34d}\n  .cred-note b{color:var(--ink)}\n  /* HF org API panel */\n  .hforg{border:1px solid var(--line);border-radius:12px;background:var(--soft);padding:16px 18px;\n    display:flex;justify-content:space-between;gap:18px;align-items:center;flex-wrap:wrap}\n  .ho-l{flex:1 1 360px}\n  .ho-t{font-size:13.5px;font-weight:700;display:flex;align-items:center;gap:8px}\n  .ho-t .pill{font-size:10px;font-weight:700;color:var(--ok);background:#f0fdf4;border:1px solid #bbf7d0;border-radius:5px;padding:1px 7px}\n  .ho-t .pill.off{color:var(--off);background:#fff;border-color:var(--line)}\n  .ho-x{font-size:12px;color:var(--muted);line-height:1.55;margin-top:7px}.ho-x b{color:var(--ink)}\n  .ho-r{text-align:right}\n  .ho-r .v{font-size:30px;font-weight:800;color:var(--accent);line-height:1}\n  .ho-r .l{font-size:10.5px;color:var(--faint);text-transform:uppercase;letter-spacing:.04em;font-weight:700;margin-top:3px}\n  .cta{font-size:12px;font-weight:700;color:#fff;background:var(--accent);border:none;border-radius:8px;padding:9px 16px;cursor:pointer}\n  .cta:hover{background:#4338ca}\n</style>\n<script>\n(function(){\n  const SAAS=['OpenAI','Google','Perplexity','Anthropic','Cohere','Mistral'];\n  const TYPE_LABEL={ml_framework:'ML framework',model_artifact:'Model artifact',llm_framework:'LLM framework',\n    llm_sdk:'LLM SDK',evaluation:'Evaluation',rag:'RAG',vector_db:'Vector DB',memory:'Memory',embedding:'Embedding',\n    agent:'Agent',fine_tuning:'Fine-tuning'};\n\n  function render(model){\n    const scan=(model&&model.data_scan_results)||{};\n    const report=(model&&model.data)||{};\n    const summ=(scan.components&&scan.components.summary)||{};\n    const byType=summ.by_type||{};\n    const byProv=summ.by_provider||{};\n    const findings=report.findings||[];\n\n    const reposScanned=report.repos_scanned||(Array.isArray(report.repo)?report.repo.length:0);\n    const reposAI=(report.inventory&&report.inventory.repos_using_ai||[]).length;\n    const pulls=findings.filter(f=>f.category==='hf_import').length;\n    const components=scan.components&&scan.components.total_detections||0;\n    const filesAI=summ.files_with_ai||0;\n    const vendors=Object.keys(byProv).length;\n\n    if(!reposScanned && !components && !findings.length){\n      document.getElementById('root').innerHTML='<div class=\"ld\">Waiting for scan data…</div>';return;}\n\n    // footprint by type\n    const typeRows=Object.keys(byType).map(k=>({k,n:byType[k].count||0})).filter(r=>r.n>0).sort((a,b)=>b.n-a.n);\n    const typeMax=Math.max(1,...typeRows.map(r=>r.n));\n    const typeBars=typeRows.map(r=>`\n      <div class=\"row\"><div class=\"nm\">${TYPE_LABEL[r.k]||r.k}</div>\n        <div class=\"track\"><div class=\"fill\" style=\"width:${Math.max(3,r.n/typeMax*100)}%\"></div></div>\n        <div class=\"ct\">${r.n}</div></div>`).join('');\n\n    // providers\n    const provRows=Object.keys(byProv).map(k=>({k,n:byProv[k]||0})).sort((a,b)=>b.n-a.n);\n    const provMax=Math.max(1,...provRows.map(r=>r.n));\n    const shown=provRows.slice(0,12), rest=provRows.slice(12);\n    const restSum=rest.reduce((s,r)=>s+r.n,0);\n    const provBars=shown.map(r=>{const isSaas=SAAS.indexOf(r.k)>-1;\n      return `<div class=\"row\"><div class=\"nm\" title=\"${r.k}\">${r.k}${isSaas?'<span class=\"saasbadge\">API</span>':''}</div>\n        <div class=\"track\"><div class=\"fill\" style=\"width:${Math.max(3,r.n/provMax*100)}%;${isSaas?'background:linear-gradient(90deg,#0891b2,#22d3ee)':''}\"></div></div>\n        <div class=\"ct\">${r.n}</div></div>`;}).join('');\n    const moreLine=rest.length?`<div class=\"more\">+ ${rest.length} more vendors (${restSum} detections) · External API providers marked <span class=\"saasbadge\">API</span></div>`\n                              :`<div class=\"more\">External API providers marked <span class=\"saasbadge\">API</span></div>`;\n\n    // hotspots — model pulls (hf_import) specifically, to match the caption\n    const pullFindings=findings.filter(f=>f.category==='hf_import');\n    const repoCt={},repoDir={};\n    pullFindings.forEach(f=>{const rp=f.repo||'—';repoCt[rp]=(repoCt[rp]||0)+1;\n      const seg=(f.file_path||'').split('/')[0]||'(root)';(repoDir[rp]=repoDir[rp]||{})[seg]=(repoDir[rp][seg]||0)+1;});\n    const hotRepos=Object.keys(repoCt).map(rp=>({rp,n:repoCt[rp]})).sort((a,b)=>b.n-a.n).slice(0,6);\n    const hotMax=Math.max(1,...hotRepos.map(r=>r.n));\n    const hotHtml=hotRepos.map(r=>{const dirs=repoDir[r.rp]||{};\n      const topDir=Object.keys(dirs).sort((a,b)=>dirs[b]-dirs[a])[0];const short=r.rp.split('/').pop();\n      return `<div class=\"hotrepo\"><div class=\"hr-top\"><span class=\"hr-name\">${short}</span><span class=\"hr-ct\"><b>${r.n}</b> pulls</span></div>\n        <div class=\"hr-track\"><div class=\"hr-fill\" style=\"width:${Math.max(4,r.n/hotMax*100)}%\"></div></div>\n        <div class=\"hr-dir\">top directory: <code>${topDir}/</code> (${dirs[topDir]})</div></div>`;}).join('')\n      || '<div class=\"more\">No model-pull hotspots found.</div>';\n\n    // HF credential references (hf_credential)\n    const credF=findings.filter(f=>f.category==='hf_credential');\n    const credTotal=credF.length;\n    const credValues=credF.filter(f=>f.metadata&&f.metadata.is_value===true).length;\n    const credRefs=credTotal-credValues;\n    const credByRepo={};\n    credF.forEach(f=>{const rp=(f.repo||'—').split('/').pop();credByRepo[rp]=(credByRepo[rp]||0)+1;});\n    const credRepos=Object.keys(credByRepo).map(rp=>({rp,n:credByRepo[rp]})).sort((a,b)=>b.n-a.n).slice(0,5);\n    const credMax=Math.max(1,...credRepos.map(r=>r.n));\n    const credByRepoHtml=credRepos.map(r=>`\n      <div class=\"cred-row\"><div class=\"rn\" title=\"${r.rp}\">${r.rp}</div>\n        <div class=\"tr\"><div class=\"fl\" style=\"width:${Math.max(4,r.n/credMax*100)}%\"></div></div>\n        <div class=\"cc\">${r.n}</div></div>`).join('');\n    const credPanel = credTotal ? `\n      <div class=\"cred\">\n        <div class=\"cred-top\">\n          <div class=\"cred-stat\"><div class=\"v\">${credTotal}</div><div class=\"l\">Token references</div></div>\n          <div class=\"cred-div\"></div>\n          <div class=\"cred-stat ${credValues?'':'muted'}\"><div class=\"v\">${credValues}</div><div class=\"l\">Exposed values</div></div>\n          <div class=\"cred-div\"></div>\n          <div class=\"cred-by\">\n            <div class=\"lab\">By repository</div>\n            ${credByRepoHtml}\n          </div>\n        </div>\n        <div class=\"cred-note\">All ${credTotal} are <b>HF_TOKEN references</b> (variable names, doc instructions, secret-setup steps) — ${credValues?`<b>${credValues} contain an actual token value</b> and need rotation`:'<b>none contain an exposed token value</b>'}. This is a <b>credential-handling surface to review</b>, not ${credValues?'only ':''}a set of leaked secrets. Concentrated in <b>${credRepos[0]?credRepos[0].rp:'—'}</b>.</div>\n      </div>` : '<div class=\"more\">No HuggingFace credential references found.</div>';\n\n    // HF org API state (connected? what did it return?)\n    const ran=report.surfaces_run||[];\n    const hfOn=ran.indexOf('hf_org_api')>-1 || ran.indexOf('huggingface_org')>-1;\n    const hfModels=(report.inventory&&report.inventory.hf_models)||[];\n    const members=((report.inventory&&report.inventory.developers_pulling_weights)||[]).length;\n    let hfOrgPanel;\n    if(hfOn && hfModels.length){\n      const tags=hfModels.map(m=>{const name=typeof m==='string'?m:(m.id||m.name||'model');const gated=typeof m==='object'&&m.gated;\n        return `<span style=\"display:inline-flex;gap:6px;font-size:12px;font-family:var(--mono);border:1px solid var(--line);border-radius:7px;padding:4px 9px;margin:3px 4px 3px 0;background:#fff\">${name}${gated?'<span style=\"font-size:9px;font-weight:700;color:#b45309;background:#fef3c7;border-radius:4px;padding:0 5px\">gated</span>':''}</span>`;}).join('');\n      hfOrgPanel=`<div class=\"ho-l\" style=\"flex:1 1 100%\"><div class=\"ho-t\">Org-owned &amp; gated models <span class=\"pill\">via HF Hub API</span></div><div style=\"margin-top:10px\">${tags}</div></div>`;\n    } else if(hfOn){\n      hfOrgPanel=`\n        <div class=\"ho-l\">\n          <div class=\"ho-t\">HuggingFace org API <span class=\"pill\">connected</span></div>\n          <div class=\"ho-x\">The org token is connected and returned <b>${members} member${members===1?'':'s'} who pulled weights</b> (see Attribution). This scan did <b>not</b> return a gated-model inventory — when the Hub model list is included, org-owned and gated models (Llama, Mixtral) appear here, including ones that leave no import trace.</div>\n        </div>\n        <div class=\"ho-r\"><div class=\"v\">${members}</div><div class=\"l\">members returned</div></div>`;\n    } else {\n      hfOrgPanel=`\n        <div class=\"ho-l\">\n          <div class=\"ho-t\">HuggingFace org API <span class=\"pill off\">not connected</span></div>\n          <div class=\"ho-x\">Connect your <b>HuggingFace organization token</b> to inventory every model the org owns or can access — including <b>gated models</b> like Llama and Mixtral that never appear as a repo import.</div>\n        </div>\n        <button class=\"cta\" id=\"hfModels\">Connect HF org token</button>`;\n    }\n\n    document.getElementById('root').innerHTML=`\n    <div class=\"wrap\">\n      <div class=\"acthead\"><span class=\"actname\">Discovery</span></div>\n      <div class=\"actsub\"><b>What AI is in use, and where.</b> This phase maps breadth — repos, components, providers, credentials, and the directories where model pulls concentrate. No severity or risk scoring happens here; that is the Posture phase.</div>\n\n      <div class=\"strip\">\n        <div class=\"stat\"><div class=\"v\">${reposScanned}</div><div class=\"l\">Repos scanned</div></div>\n        <div class=\"stat em\"><div class=\"v\">${reposAI}</div><div class=\"l\">Repos pulling models</div></div>\n        <div class=\"stat em\"><div class=\"v\">${pulls}</div><div class=\"l\">Model pulls</div></div>\n        <div class=\"stat\"><div class=\"v\">${components}</div><div class=\"l\">AI components</div></div>\n        <div class=\"stat\"><div class=\"v\">${filesAI}</div><div class=\"l\">Files with AI</div></div>\n        <div class=\"stat\"><div class=\"v\">${vendors}</div><div class=\"l\">Vendors</div></div>\n      </div>\n\n      <div class=\"cols\">\n        <div class=\"pblock\"><div class=\"ptitle\">Footprint by type</div>\n          <div class=\"pcap\">AI components detected across the codebase, by category</div>${typeBars}</div>\n        <div class=\"pblock\"><div class=\"ptitle\">Providers</div>\n          <div class=\"pcap\">Detections per vendor / tool · top 12 shown</div>${provBars}${moreLine}</div>\n      </div>\n\n      <div class=\"pblock\"><div class=\"ptitle\">Hotspots</div>\n        <div class=\"pcap\">Repos where model pulls concentrate, with the heaviest directory</div>\n        <div class=\"hot\">${hotHtml}</div></div>\n\n      <div class=\"pblock\"><div class=\"ptitle\">HuggingFace credential references</div>\n        <div class=\"pcap\">HF_TOKEN references found in code — references vs actual exposed values are counted separately</div>\n        ${credPanel}</div>\n\n      <div class=\"pblock\" style=\"margin-bottom:0\"><div class=\"ptitle\">HuggingFace org API</div>\n        <div class=\"pcap\">What the organization token surfaced — members, and (when included) the owned / gated model inventory</div>\n        <div class=\"hforg\">${hfOrgPanel}</div></div>\n    </div>`;\n\n    const b=document.getElementById('hfModels');\n    if(b) b.onclick=function(){b.textContent='Wire to your HF-org query';};\n  }\n  function boot(){if(typeof appsmith==='undefined'){setTimeout(boot,50);return;}\n    appsmith.onReady(function(){render(appsmith.model);});\n    if(appsmith.onModelChange)appsmith.onModelChange(function(m){render(m);});}\n  boot();\n})();\n</script>",
    "js": ""
  },
  "version": 1,
  "widgetId": "cc1abm5uwb",
  "widgetName": "Custom1"
}