    "css": "",
    "html": "<div id=\"root\"><div class=\"ld\">Waiting for scan data…</div></div>\n<style>\n  :root{--ink:#0f172a;--muted:#64748b;--faint:#94a3b8;--line:#e8edf3;--panel:#fff;--soft:#f8fafc;\n    --ok:#16a34a;--off:#94a3b8;--accent:#4f46e5;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;--mono:ui-monospace,Menlo,Consolas,monospace;}\n  *{box-sizing:border-box}html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .ld{padding:20px;color:var(--faint);font-size:13px}\n  .wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:14px 20px;box-shadow:0 1px 2px rgba(15,23,42,.04)}\n  .lbl{font-size:10.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--faint);font-weight:700;margin-bottom:11px}\n  .surf{display:flex;gap:10px;flex-wrap:wrap}\n  .s{flex:1 1 180px;display:flex;align-items:center;gap:11px;border:1px solid var(--line);border-radius:11px;padding:11px 14px;background:var(--soft)}\n  .s.off{border-style:dashed;background:#fff}\n  .mk{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex:0 0 auto}\n  .mk.on{background:var(--ok)} .mk.no{background:var(--off)}\n  .s .nm{font-size:13px;font-weight:700;font-family:var(--mono)}\n  .s .st{font-size:11px;color:var(--muted);margin-top:1px}\n  .s.off .st{color:var(--off)}\n  .cta{margin-left:auto;font-size:11px;font-weight:700;color:#fff;background:var(--accent);border:none;border-radius:7px;padding:7px 11px;cursor:pointer;white-space:nowrap}\n  .cta:hover{background:#4338ca}\n</style>\n<script>\n(function(){\n  function render(model){\n    const report=(model&&model.data)||{};\n    const ran=report.surfaces_run||[];\n    const bs=(report.totals&&report.totals.by_surface)||{};\n    const devs=((report.inventory&&report.inventory.developers_pulling_weights)||[]).length;\n    if(!ran.length && !report.repos_scanned){\n      document.getElementById('root').innerHTML='<div class=\"ld\">Waiting for scan data…</div>';return;}\n\n    const has=s=>ran.indexOf(s)>-1;\n    const hfOn=has('hf_org_api')||has('huggingface_org');\n    const surfaces=[\n      {key:'code_repo',name:'code_repo',on:has('code_repo'),\n        st:has('code_repo')?`scanned · ${bs.code_repo||0} findings`:'not run'},\n      {key:'cicd',name:'cicd',on:has('cicd'),\n        st:has('cicd')?`scanned · ${bs.cicd||0} finding${(bs.cicd||0)===1?'':'s'}`:'not run'},\n      {key:'hf_org_api',name:'hf_org_api',on:hfOn,\n        st:hfOn?`connected · ${devs} member${devs===1?'':'s'} pulled weights`:'not connected — needs org token'}\n    ];\n    const cards=surfaces.map(s=>`\n      <div class=\"s ${s.on?'':'off'}\">\n        <span class=\"mk ${s.on?'on':'no'}\">${s.on?'✓':'○'}</span>\n        <div><div class=\"nm\">${s.name}</div><div class=\"st\">${s.st}</div></div>\n        ${!s.on && s.key==='hf_org_api'?'<button class=\"cta\" id=\"hfConnect\">Connect HF org token</button>':''}\n      </div>`).join('');\n\n    document.getElementById('root').innerHTML=`\n    <div class=\"wrap\">\n      <div class=\"lbl\">Scan coverage — surfaces examined</div>\n      <div class=\"surf\">${cards}</div>\n    </div>`;\n    const b=document.getElementById('hfConnect');\n    if(b) b.onclick=function(){b.textContent='Wire to your HF-org query';};\n  }\n  function boot(){if(typeof appsmith==='undefined'){setTimeout(boot,50);return;}\n    appsmith.onReady(function(){render(appsmith.model);});\n    if(appsmith.onModelChange)appsmith.onModelChange(function(m){render(m);});}\n  boot();\n})();\n</script>",
    "js": ""
  },
