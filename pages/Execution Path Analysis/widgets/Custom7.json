    "html": "<div id=\"root\"><div class=\"ld\">Waiting for scan data…</div></div>\n\n<style>\n  :root{\n    --ink:#0f172a;--muted:#64748b;--faint:#94a3b8;--line:#e8edf3;\n    --panel:#fff;--soft:#f8fafc;--accent:#4f46e5;\n    --crit:#dc2626;--high:#ea580c;--med:#d97706;--low:#2563eb;\n    --ok:#16a34a;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .ld{padding:28px;color:var(--faint);font-size:13px}\n  .wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;\n    padding:20px 22px;box-shadow:0 1px 2px rgba(15,23,42,.04)}\n  .acthead{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:4px}\n  .actname{font-size:18px;font-weight:700;letter-spacing:-.01em}\n  .actstep{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;\n    color:#fff;background:var(--accent);border-radius:6px;padding:3px 8px}\n  .actsub{font-size:12.5px;color:var(--muted);line-height:1.5;margin:6px 0 18px;\n    padding-left:11px;border-left:3px solid var(--accent)}\n  .actsub b{color:var(--ink)}\n  .ptitle{font-size:13px;font-weight:700;margin-bottom:2px}\n  .pcap{font-size:11px;color:var(--faint);margin-bottom:12px}\n  .pblock{margin-bottom:24px}\n\n  .leadnote{display:flex;align-items:center;gap:10px;background:#fef2f2;border:1px solid #fecaca;\n    border-radius:10px;padding:11px 14px;margin-bottom:14px;font-size:13px}\n  .leadnote .swing{font-family:var(--mono);font-weight:800}\n  .leadnote .swing .from{color:var(--crit)} .leadnote .swing .to{color:var(--ok)}\n\n  table{width:100%;border-collapse:collapse}\n  thead th{font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);\n    font-weight:700;text-align:left;padding:8px 10px;border-bottom:1px solid var(--line)}\n  thead th.r,tbody td.r{text-align:right}\n  tbody td{padding:12px 10px;border-bottom:1px solid var(--line);font-size:12.5px;vertical-align:top}\n  tbody tr:last-child td{border-bottom:none}\n  tbody tr.top td{background:#fffafa}\n  .sev{font-size:10px;font-weight:800;text-transform:uppercase;color:#fff;border-radius:5px;padding:2px 7px;display:inline-block}\n  .find{font-weight:600;font-size:12.5px}\n  .findloc{font-family:var(--mono);font-size:11px;color:var(--faint);margin-top:3px}\n  .impact{font-family:var(--mono);font-weight:800;font-size:13px;white-space:nowrap}\n  .impact .d{font-size:11px;font-weight:700;color:var(--ok);margin-left:4px}\n  .impact .d0{color:var(--faint)}\n  .rec{font-size:11.5px;color:var(--muted);line-height:1.4;max-width:280px}\n  .route{font-size:11.5px;border:1px solid var(--line);border-radius:7px;padding:5px 8px;background:#fff;color:var(--ink);font-family:var(--sans)}\n  .status{font-size:10px;font-weight:700;text-transform:uppercase;border-radius:5px;padding:3px 8px;\n    color:var(--high);background:#fff7ed;border:1px solid #fed7aa}\n\n  /* blind spots */\n  .bs{border:1px solid var(--line);border-radius:11px;padding:14px 16px;margin:9px 0;background:var(--soft);display:flex;gap:12px}\n  .bs .ic{font-size:16px;line-height:1.3}\n  .bs.clean{background:#f0fdf4;border-color:#bbf7d0}\n  .bs .t{font-size:13px;font-weight:700;margin-bottom:3px}\n  .bs.clean .t{color:#15803d}\n  .bs .body{font-size:12px;color:var(--muted);line-height:1.5}\n  .bs .body b{color:var(--ink)}\n  .bs .fwd{font-size:11.5px;color:var(--accent);margin-top:6px}\n\n  /* methodology footer */\n  .meth{background:#0f172a;border-radius:14px;padding:22px 24px;color:#e2e8f0;margin-top:6px}\n  .meth h4{margin:0 0 4px;font-size:14px;font-weight:700;color:#fff}\n  .meth .sub{font-size:11.5px;color:#94a3b8;margin-bottom:16px}\n  .methgrid{display:grid;grid-template-columns:1fr 1fr;gap:22px}\n  @media(max-width:720px){.methgrid{grid-template-columns:1fr}}\n  .meth .eq{font-family:var(--mono);font-size:12.5px;background:#1e293b;border-radius:8px;padding:11px 13px;color:#e2e8f0;line-height:1.7;margin-bottom:12px}\n  .meth .eq b{color:#a5b4fc}\n  .meth .lbl{font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:#64748b;font-weight:700;margin:0 0 7px}\n  .mtab{width:100%;border-collapse:collapse;font-size:11.5px}\n  .mtab td{padding:4px 6px;border-bottom:1px solid #1e293b;color:#cbd5e1}\n  .mtab td.r{text-align:right;font-family:var(--mono);font-weight:700;color:#fff}\n  .bands{display:flex;gap:4px;margin-top:6px;flex-wrap:wrap}\n  .bands span{font-size:10px;font-weight:700;color:#fff;border-radius:5px;padding:3px 8px}\n  .worked{font-size:11.5px;color:#cbd5e1;line-height:1.6;background:#1e293b;border-radius:8px;padding:11px 13px;margin-top:12px}\n  .worked b{color:#fff} .worked .g{color:#4ade80;font-weight:700}\n  .knobs{font-size:10.5px;color:#64748b;margin-top:12px;line-height:1.5}\n</style>\n\n<script>\n(function(){\n  const SEVC={critical:'#dc2626',high:'#ea580c',medium:'#d97706',low:'#2563eb'};\n  const pts={critical:12,high:5,medium:2,low:0.25};\n  const sevRank={critical:4,high:3,medium:2,low:1};\n  const anchorMap={4:75,3:50,2:28,1:12,0:0};\n\n  function score(buckets){\n    const b=buckets.filter(x=>x.n>0);\n    let raw=0,worst=0;\n    b.forEach(x=>{raw+=pts[x.sev]*Math.min(1+Math.log(x.n),5);worst=Math.max(worst,sevRank[x.sev]);});\n    const vol=25*(1-Math.exp(-raw/30));\n    return Math.round(Math.min(100,(anchorMap[worst]||0)+vol));\n  }\n  function band(s){return s<=20?'Low':s<=45?'Moderate':s<=70?'Elevated':s<=90?'High':'Critical';}\n\n  function render(model){\n    const scan=(model&&model.data_scan_results)||{};\n    const report=(model&&model.data)||{};\n    const cr=scan.crossings||{};\n    const crit=cr.critical_count||0, high=cr.high_count||0, med=cr.medium_count||0;\n    const mart=(scan.components&&scan.components.summary&&scan.components.summary.by_type&&scan.components.summary.by_type.model_artifact)||{providers:{}};\n    const pickle=(mart.providers&&mart.providers.Pickle||[]).length;\n    const pulls=(report.findings||[]).filter(f=>f.category==='hf_import').length;\n\n    if(!crit && !high && !pulls){\n      document.getElementById('root').innerHTML='<div class=\"ld\">Waiting for scan data…</div>';return;\n    }\n\n    // critical crossing detail\n    let critFile='', critRec='';\n    (cr.crossings||[]).some(c=>{if(c.severity==='critical'){critFile=c.file+':'+c.line;critRec=c.recommendation||'';return true;}return false;});\n\n    // baseline buckets\n    const base=[\n      {sev:'critical',n:crit,key:'cred'},\n      {sev:'high',n:high,key:'highflows'},\n      {sev:'high',n:pickle,key:'pickle'},\n      {sev:'medium',n:med,key:'medflow'},\n      {sev:'low',n:pulls,key:'pulls'}\n    ];\n    const baseScore=score(base);\n    const resolved=key=>score(base.map(b=>b.key===key?{...b,n:0}:b));\n\n    const ACT={\n      cred:{title:'Remove database credential from LLM-prompt path',sev:'critical',loc:critFile,rec:critRec||'Remove the credential before it reaches the AI provider.'},\n      highflows:{title:`Add safeguards to ${high} high-severity sensitive→AI flows`,sev:'high',loc:'PII / financial / internal → LLM',rec:'Mask, tokenize, or gate these values before the AI boundary.'},\n      pickle:{title:'Replace or sign the unsigned Pickle artifact',sev:'high',loc:'serialization format',rec:'Convert to safetensors or sign and verify before load.'},\n      medflow:{title:'Review medium PII flow (IP address → LLM prompt)',sev:'medium',loc:'backend-agent/main.py',rec:'Confirm IP logging into prompts is intended; redact if not.'},\n      pulls:{title:`Pin ${pulls} unpinned from_pretrained revisions`,sev:'low',loc:'model pulls',rec:'Pin to commit hashes and load from an internal mirror.'}\n    };\n\n    const rows=base.filter(b=>b.n>0).map(b=>{\n      const a=ACT[b.key], rs=resolved(b.key), delta=baseScore-rs;\n      return {key:b.key,...a,resolved:rs,delta};\n    }).sort((x,y)=>y.delta-x.delta);\n\n    const topDrop=rows[0];\n\n    const tr=rows.map((r,i)=>`\n      <tr class=\"${i===0?'top':''}\">\n        <td><span class=\"sev\" style=\"background:${SEVC[r.sev]}\">${r.sev}</span></td>\n        <td><div class=\"find\">${r.title}</div><div class=\"findloc\">${r.loc}</div></td>\n        <td class=\"r\"><span class=\"impact\">${baseScore}→${r.resolved}${r.delta>0?`<span class=\"d\">−${r.delta}</span>`:`<span class=\"d d0\">±0</span>`}</span></td>\n        <td><div class=\"rec\">${r.rec}</div></td>\n        <td><select class=\"route\"><option>Open ticket…</option><option>Jira</option><option>ServiceNow</option><option>Assign owner</option></select></td>\n        <td><span class=\"status\">Open</span></td>\n      </tr>`).join('');\n\n    // blind spots\n    const gap=report.honest_gap||{};\n    const surfaces=report.surfaces_run||[];\n    const cicdRan=surfaces.indexOf('cicd')>-1;\n    const cicdFindings=(report.totals&&report.totals.by_surface&&report.totals.by_surface.cicd)||0;\n\n    // worked example numbers (dynamic)\n    const fixCredScore=resolved('cred');\n\n    document.getElementById('root').innerHTML=`\n    <div class=\"wrap\">\n      <div class=\"acthead\"><span class=\"actname\">Action</span><span class=\"actstep\">Act 4 of 4</span></div>\n      <div class=\"actsub\"><b>What to fix first, and who owns it.</b> Every item is ranked by how much it moves the Posture Score, not by raw count — so the queue reflects real risk reduction. Route each to your tracker to close the loop.</div>\n\n      <div class=\"pblock\">\n        <div class=\"ptitle\">Action queue</div>\n        <div class=\"pcap\">Prioritized by score impact · resolving the top item is worth more than all others combined</div>\n        <div class=\"leadnote\">🔻 <div>Fixing the top item moves Posture <span class=\"swing\"><span class=\"from\">${baseScore}</span> → <span class=\"to\">${topDrop.resolved}</span></span> (−${topDrop.delta}, ${band(baseScore)} → ${band(topDrop.resolved)}). Everything below it is secondary until this is closed.</div></div>\n        <table>\n          <thead><tr><th>Severity</th><th>Finding</th><th class=\"r\">Score impact</th><th>Recommendation</th><th>Route</th><th>Status</th></tr></thead>\n          <tbody>${tr}</tbody>\n        </table>\n      </div>\n\n      <div class=\"pblock\" style=\"margin-bottom:0\">\n        <div class=\"ptitle\">Known blind spots & coverage</div>\n        <div class=\"pcap\">What this scan does and does not see — stated plainly</div>\n        <div class=\"bs\">\n          <div class=\"ic\">⚠️</div>\n          <div>\n            <div class=\"t\">${(gap.surface||'local_endpoint').replace('_',' ')} — not covered</div>\n            <div class=\"body\">${gap.summary||'Models pulled to individual developer laptops outside any repo or pipeline are not visible from source control or the Hub API.'}</div>\n            ${gap.path_forward?`<div class=\"fwd\">Path forward: ${gap.path_forward}</div>`:''}\n          </div>\n        </div>\n        <div class=\"bs clean\">\n          <div class=\"ic\">✓</div>\n          <div>\n            <div class=\"t\">CI/CD — scanned, ${cicdFindings} findings</div>\n            <div class=\"body\">${cicdRan?`CI/CD pipelines <b>were scanned and returned ${cicdFindings} findings</b> — this is verified coverage, not a gap. A clean surface is a result, not a blind spot.`:'CI/CD scanning was not run in this scan.'}</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"meth\">\n      <h4>How the Posture Score is computed</h4>\n      <div class=\"sub\">Severity-weighted · only the Posture phase emits this number · Discovery never does.</div>\n      <div class=\"methgrid\">\n        <div>\n          <div class=\"eq\"><b>Posture Score</b> = min(100, <b>Anchor</b> + <b>Volume</b>)</div>\n          <div class=\"lbl\">Anchor — floor set by the single worst finding</div>\n          <table class=\"mtab\">\n            <tr><td>Critical present</td><td class=\"r\">75</td></tr>\n            <tr><td>High present</td><td class=\"r\">50</td></tr>\n            <tr><td>Medium present</td><td class=\"r\">28</td></tr>\n            <tr><td>Low present</td><td class=\"r\">12</td></tr>\n            <tr><td>None</td><td class=\"r\">0</td></tr>\n          </table>\n          <div class=\"lbl\" style=\"margin-top:12px\">Bands</div>\n          <div class=\"bands\">\n            <span style=\"background:#16a34a\">≤20 Low</span>\n            <span style=\"background:#ca8a04\">≤45 Moderate</span>\n            <span style=\"background:#ea580c\">≤70 Elevated</span>\n            <span style=\"background:#dc2626\">≤90 High</span>\n            <span style=\"background:#991b1b\">&gt;90 Critical</span>\n          </div>\n        </div>\n        <div>\n          <div class=\"lbl\">Volume — saturating breadth bonus (cap 25)</div>\n          <div class=\"eq\">raw = Σ <b>pts(sev)</b> × min(1 + ln(n), 5)<br>Volume = 25 × (1 − e<sup>−raw/30</sup>)</div>\n          <div class=\"lbl\">pts per severity</div>\n          <table class=\"mtab\">\n            <tr><td>Critical</td><td class=\"r\">12</td></tr>\n            <tr><td>High</td><td class=\"r\">5</td></tr>\n            <tr><td>Medium</td><td class=\"r\">2</td></tr>\n            <tr><td>Low</td><td class=\"r\">0.25</td></tr>\n          </table>\n          <div class=\"worked\">\n            <b>This scan:</b> worst = Critical → Anchor 75; raw ≈ 36.8 → Volume ≈ 18 → <b>${baseScore} (${band(baseScore)})</b>.<br>\n            Remove the one credential leak → worst = High → Anchor 50 → <span class=\"g\">${fixCredScore} (${band(fixCredScore)})</span>. One fix, two bands.\n          </div>\n          <div class=\"knobs\">The ln-with-cap term keeps 192 low findings from inflating the score (counts as one log-scaled Low, not 192 points). Anchor values, pts, the saturation constant (30) and band cutoffs are tunable; frozen for v1.</div>\n        </div>\n      </div>\n    </div>`;\n  }\n\n  function boot(){\n    if(typeof appsmith==='undefined'){setTimeout(boot,50);return;}\n    appsmith.onReady(function(){render(appsmith.model);});\n    if(appsmith.onModelChange) appsmith.onModelChange(function(m){render(m);});\n  }\n  boot();\n})();\n</script>",
    "js": ""
  },
  "version": 1,
  "widgetId": "yo4heg5lg7",
  "widgetName": "Custom7"
}