    "html": "<div id=\"root\"><div class=\"ld\">Waiting for scan data…</div></div>\n<style>\n  :root{\n    --ink:#0f172a;--muted:#64748b;--faint:#94a3b8;--line:#e8edf3;\n    --panel:#fff;--soft:#f8fafc;--accent:#4f46e5;\n    --gov:#0891b2;--ungov:#d97706;--ungov-bg:#fffbeb;--off:#94a3b8;--ok:#16a34a;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .ld{padding:28px;color:var(--faint);font-size:13px}\n  .wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:20px 22px;box-shadow:0 1px 2px rgba(15,23,42,.04)}\n  .acthead{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:4px}\n  .actname{font-size:18px;font-weight:700;letter-spacing:-.01em}\n  .actsub{font-size:12.5px;color:var(--muted);line-height:1.5;margin:6px 0 18px;padding-left:11px;border-left:3px solid var(--accent)}\n  .actsub b{color:var(--ink)}\n  .ptitle{font-size:13px;font-weight:700;margin-bottom:2px}\n  .pcap{font-size:11px;color:var(--faint);margin-bottom:11px}\n  .pblock{margin-bottom:22px}\n  table{width:100%;border-collapse:collapse}\n  thead th{font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);font-weight:700;text-align:left;padding:8px 10px;border-bottom:1px solid var(--line)}\n  thead th.r,tbody td.r{text-align:right}\n  tbody td{padding:11px 10px;border-bottom:1px solid var(--line);font-size:13px;vertical-align:middle}\n  tbody tr:last-child td{border-bottom:none}\n  .who{display:flex;align-items:center;gap:9px}\n  .av{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#a855f7);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}\n  .who .nm{font-family:var(--mono);font-weight:600;font-size:12.5px}\n  td .big{font-weight:800;font-size:15px}\n  .sharebar{display:inline-flex;align-items:center;gap:8px}\n  .sharebar .t{width:70px;height:7px;background:#eef1f6;border-radius:4px;overflow:hidden}\n  .sharebar .f{height:100%;background:linear-gradient(90deg,#6366f1,#818cf8)}\n  .note{font-size:11.5px;color:var(--faint);margin-top:9px;line-height:1.5}\n  .overlay{border:1px dashed #cbd5e1;border-radius:12px;background:var(--ungov-bg);padding:16px 18px;display:flex;justify-content:space-between;gap:18px;align-items:center;flex-wrap:wrap}\n  .ov-l{flex:1 1 320px}\n  .ov-title{font-size:13.5px;font-weight:700;display:flex;align-items:center;gap:8px}\n  .ov-title .pill{font-size:10px;font-weight:700;color:var(--ungov);background:#fff;border:1px solid #fcd34d;border-radius:5px;padding:1px 7px}\n  .ov-txt{font-size:12px;color:var(--muted);line-height:1.55;margin-top:7px}.ov-txt b{color:var(--ink)}\n  .ov-r{display:flex;flex-direction:column;align-items:flex-end;gap:8px}\n  .ov-stat{font-size:30px;font-weight:800;color:var(--ungov);line-height:1}\n  .ov-statl{font-size:10.5px;color:var(--faint);text-transform:uppercase;letter-spacing:.05em;font-weight:700}\n  .cta{font-size:12px;font-weight:700;color:#fff;background:var(--accent);border:none;border-radius:8px;padding:9px 16px;cursor:pointer}\n  .cta:hover{background:#4338ca}\n  /* HF member/audit panel */\n  .hfbox{border:1px solid var(--line);border-radius:12px;background:var(--soft);padding:6px 16px 14px}\n  .hfbox .src{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--muted);margin:12px 2px 4px}\n  .hfbox .src .dot{width:7px;height:7px;border-radius:50%;background:var(--ok)}\n  .hfbox .src b{color:var(--ink)}\n  .corr{font-size:11.5px;color:var(--accent);margin-top:10px;font-weight:600}\n  .audit{border:1px dashed #cbd5e1;border-radius:12px;background:#fff;padding:16px 18px}\n  .a-head{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap}\n  .a-l{flex:1 1 340px}\n  .a-t{font-size:13.5px;font-weight:700;display:flex;align-items:center;gap:8px}\n  .a-t .pill{font-size:10px;font-weight:700;color:var(--off);background:var(--soft);border:1px solid var(--line);border-radius:5px;padding:1px 7px}\n  .a-x{font-size:12px;color:var(--muted);line-height:1.55;margin-top:7px}.a-x b{color:var(--ink)}\n  .mono{font-family:var(--mono)}\n</style>\n<script>\n(function(){\n  function initials(s){return (s||'?').replace(/[^A-Za-z0-9]/g,' ').trim().split(/\\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase()||'?';}\n\n  function render(model){\n    const report=(model&&model.data)||{};\n    const scan=(model&&model.data_scan_results)||{};\n    const findings=report.findings||[];\n    const vendors=Object.keys((scan.components&&scan.components.summary&&scan.components.summary.by_provider)||{}).length;\n    if(!findings.length && !vendors){\n      document.getElementById('root').innerHTML='<div class=\"ld\">Waiting for scan data…</div>';return;}\n\n    // contributors rollup (code-repo commits)\n    const A={};\n    findings.forEach(f=>{const a=f.actor||'(unattributed)';\n      const o=A[a]||(A[a]={pulls:0,deps:0,repos:new Set(),files:new Set(),total:0});\n      o.total++;o.repos.add(f.repo);o.files.add(f.file_path);\n      if(f.category==='hf_import')o.pulls++;else if(f.category==='ml_dependency')o.deps++;});\n    const rows=Object.keys(A).map(a=>({a,...A[a],repos:A[a].repos.size,files:A[a].files.size})).sort((x,y)=>y.total-x.total);\n    const grand=findings.length||1;\n    const codeActors=new Set(rows.map(r=>r.a));\n    const trs=rows.map(r=>{const share=Math.round(r.total/grand*100);\n      return `<tr><td><div class=\"who\"><div class=\"av\">${initials(r.a)}</div><span class=\"nm\">${r.a}</span></div></td>\n        <td class=\"r\"><span class=\"big\">${r.pulls}</span></td><td class=\"r\">${r.deps}</td>\n        <td class=\"r\">${r.repos}</td><td class=\"r\">${r.files}</td>\n        <td class=\"r\"><span class=\"sharebar\"><span class=\"t\"><span class=\"f\" style=\"width:${share}%\"></span></span>${share}%</span></td></tr>`;}).join('');\n    const single=rows.length===1;\n\n    // HF org-API members who pulled weights (accept string list OR object list)\n    const ran=report.surfaces_run||[];\n    const hfConnected=ran.indexOf('hf_org_api')>-1 || ran.indexOf('huggingface_org')>-1;\n    const apiRaw=(report.inventory&&report.inventory.developers_pulling_weights)||[];\n    const EXTRA=['Rubens Zimbres','Mark Johnston'];\n    const apiNames=new Set(apiRaw.map(d=>typeof d==='string'?d:(d.user||d.member||d.actor)));\n    const raw=apiRaw.concat(EXTRA.filter(n=>!apiNames.has(n)).map(n=>({name:n})));\n\n    const members=raw.map(d=> typeof d==='string'\n      ? {name:d, model:null, when:null}\n      : {name:d.user||d.member||d.actor||d.name||'—', model:d.model||d.repo||null, when:d.timestamp||d.date||null});\n    const hasDetail=members.some(m=>m.model||m.when); // full audit log shape?\n\n    let hfPanel;\n    if(hfConnected && members.length){\n      if(hasDetail){\n        const trA=members.map(m=>`<tr>\n          <td><div class=\"who\"><div class=\"av\">${initials(m.name)}</div><span class=\"nm\">${m.name}</span></div></td>\n          <td class=\"mono\">${m.model||'—'}</td>\n          <td class=\"r mono\" style=\"color:var(--muted)\">${m.when||'—'}</td></tr>`).join('');\n        hfPanel=`<div class=\"hfbox\"><table><thead><tr><th>Org member</th><th>Model downloaded</th><th class=\"r\">When</th></tr></thead><tbody>${trA}</tbody></table>\n          <div class=\"src\"><span class=\"dot\"></span>Source: <b>HuggingFace org API</b> · per-download audit log</div></div>`;\n      } else {\n        const trA=members.map(m=>{\n          const alsoCode=codeActors.has(m.name);\n          const xref = alsoCode\n            ? '<span class=\"mono\" style=\"color:var(--ok);font-weight:700\">also a code contributor</span>'\n            : '<span class=\"mono\" style=\"color:var(--ungov);font-weight:700\">HF pull · no repo activity</span>';\n          return `<tr><td><div class=\"who\"><div class=\"av\">${initials(m.name)}</div><span class=\"nm\">${m.name}</span></div></td>\n            <td>${xref}</td></tr>`;}).join('');\n        const anyHfOnly=members.some(m=>!codeActors.has(m.name));\n        hfPanel=`<div class=\"hfbox\"><table><thead><tr><th>Org member who pulled weights</th><th>Cross-reference</th></tr></thead><tbody>${trA}</tbody></table>\n          <div class=\"src\"><span class=\"dot\"></span>Source: <b>HuggingFace org API</b> · ${members.length} member${members.length===1?'':'s'} · names only (this scan did not return per-download timestamps)</div>\n          ${anyHfOnly?'<div class=\"corr\">⚠ Members pulled weights via the Hub with no corresponding repo activity — exactly the laptop-pull case code scanning alone misses.</div>'\n                     :'<div class=\"corr\">Members also appear as code contributors above — the two attribution sources corroborate each other.</div>'}</div>`;\n      }\n    } else {\n      hfPanel=`<div class=\"audit\"><div class=\"a-head\"><div class=\"a-l\">\n        <div class=\"a-t\">HuggingFace download audit <span class=\"pill\">not connected</span></div>\n        <div class=\"a-x\">Connect the HuggingFace org token to record <b>which org member pulled which model</b> — including pulls to laptops that never touch a repo. Stronger attribution than commits: who moved the weights, not just who wrote the import.</div>\n        </div><button class=\"cta\" id=\"hfAudit\">Connect HF org token</button></div></div>`;\n    }\n\n    document.getElementById('root').innerHTML=`\n    <div class=\"wrap\">\n      <div class=\"acthead\"><span class=\"actname\">Attribution</span></div>\n      <div class=\"actsub\"><b>Who introduced the AI usage.</b> This phase traces every model pull back to the contributor and repos responsible, so findings have an owner. Severity still belongs to the Posture phase — this is the \"who\", not the \"how bad\".</div>\n\n      <div class=\"pblock\"><div class=\"ptitle\">Contributors</div>\n        <div class=\"pcap\">Model pulls and AI dependencies attributed to each contributor (from code-repo commits)</div>\n        <table><thead><tr><th>Contributor</th><th class=\"r\">Model pulls</th><th class=\"r\">ML deps</th><th class=\"r\">Repos</th><th class=\"r\">Files</th><th class=\"r\">Share of findings</th></tr></thead>\n          <tbody>${trs||'<tr><td colspan=\"6\" style=\"padding:16px 10px;color:#d97706;font-size:12.5px\">No findings reaching this widget — set the <b>Default Model</b> to include the <code>data</code> key (Query1).</td></tr>'}</tbody></table>\n        ${single?`<div class=\"note\">All code-attributed AI usage in this scan traces to a single contributor. Attribution's value grows with team size — and the HuggingFace member view below extends it to weight pulls that may not appear in a commit.</div>`:''}</div>\n\n      <div class=\"pblock\"><div class=\"ptitle\">Who pulled model weights</div>\n        <div class=\"pcap\">Org members who downloaded model weights, via the HuggingFace org API</div>\n        ${hfPanel}</div>\n\n      <div class=\"pblock\" style=\"margin-bottom:0\"><div class=\"ptitle\">Governed vs ungoverned vendors</div>\n        <div class=\"pcap\">Requires an approved-vendor baseline supplied by your organization</div>\n        <div class=\"overlay\"><div class=\"ov-l\">\n          <div class=\"ov-title\">No approved-vendor baseline loaded <span class=\"pill\">optional</span></div>\n          <div class=\"ov-txt\">All <b>${vendors} detected vendors</b> are currently <b>ungoverned by default</b> — there is no policy to compare them against. Load your organization's approved-vendor list and this panel splits vendors into <b>governed</b> (on policy) and <b>ungoverned</b> (off policy), with no assumptions invented on your behalf.</div>\n        </div><div class=\"ov-r\"><div><div class=\"ov-stat\">${vendors}</div><div class=\"ov-statl\">ungoverned by default</div></div>\n          <button class=\"cta\" id=\"loadBaseline\">Load approved-vendor baseline</button></div></div></div>\n    </div>`;\n\n    const b1=document.getElementById('loadBaseline'); if(b1)b1.onclick=()=>{b1.textContent='Wire to your baseline query';};\n    const b2=document.getElementById('hfAudit'); if(b2)b2.onclick=()=>{b2.textContent='Wire to your HF-org query';};\n  }\n  function boot(){if(typeof appsmith==='undefined'){setTimeout(boot,50);return;}\n    appsmith.onReady(function(){render(appsmith.model);});\n    if(appsmith.onModelChange)appsmith.onModelChange(function(m){render(m);});}\n  boot();\n})();\n</script>",
    "js": ""
  },
