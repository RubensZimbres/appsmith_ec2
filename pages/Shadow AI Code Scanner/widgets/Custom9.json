    "html": "<div id=\"root\" class=\"aue-wrap\">\n  <div class=\"aue-loading\">Waiting for scan data…</div>\n</div>\n<style>\n  :root{\n    --ink:#0f172a; --muted:#64748b; --faint:#94a3b8; --line:#e8edf3;\n    --panel:#ffffff; --soft:#f8fafc;\n    --crit:#dc2626; --high:#ea580c; --med:#d97706; --low:#2563eb;\n    --b-low:#16a34a; --b-mod:#ca8a04; --b-elev:#ea580c; --b-high:#dc2626; --b-crit:#991b1b;\n    --accent:#4f46e5;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .aue-loading{padding:28px;color:var(--faint);font-size:13px}\n  .aue-pagetitle{text-align:center;font-size:26px;font-weight:800;letter-spacing:-.02em;margin:0 0 18px;color:var(--ink)}\n  .aue-wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:20px 22px;box-shadow:0 1px 2px rgba(15,23,42,.04);}\n  .aue-top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}\n  .aue-title{font-size:20px;font-weight:700;letter-spacing:-.01em}\n  .aue-prov{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}\n  .chip{font-size:11px;color:var(--muted);background:var(--soft);border:1px solid var(--line);border-radius:999px;padding:3px 9px;font-weight:500}\n  .chip b{color:var(--ink);font-weight:600}\n  .phases{display:flex;align-items:center;gap:8px;background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:7px 12px}\n  .ph{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--ink)}\n  .ph .dot{width:7px;height:7px;border-radius:50%;background:#16a34a}\n  .ph small{color:var(--faint);font-weight:500}\n  .arrow{color:var(--faint);font-size:13px}\n  .aue-sub{margin:14px 0 16px;font-size:13px;color:var(--muted);line-height:1.5;padding-left:11px;border-left:3px solid var(--accent)}\n  .aue-main{display:flex;gap:22px;flex-wrap:wrap}\n  .aue-headline{flex:1 1 360px;font-size:15px;line-height:1.7;color:#334155}\n  .aue-headline .n{font-weight:700;color:var(--ink)}\n  .aue-headline .crit{color:var(--crit);font-weight:700}\n  .aue-headline .warn{color:var(--high);font-weight:700}\n  .scorecard{flex:0 0 280px;border:1px solid var(--line);border-radius:12px;padding:16px 18px;background:linear-gradient(180deg,#fff,var(--soft))}\n  .sc-label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--faint);font-weight:700}\n  .sc-num{display:flex;align-items:baseline;gap:4px;margin:2px 0 4px}\n  .sc-num span{font-size:46px;font-weight:800;line-height:1;letter-spacing:-.03em}\n  .sc-num small{font-size:16px;color:var(--faint);font-weight:600}\n  .sc-band{display:inline-block;font-size:12px;font-weight:700;color:#fff;border-radius:6px;padding:3px 10px;letter-spacing:.02em}\n  .bandbar{position:relative;height:8px;border-radius:5px;overflow:hidden;display:flex;margin:14px 0 6px}\n  .bandbar .seg{height:100%}\n  .marker{position:absolute;top:-4px;width:3px;height:16px;background:var(--ink);border-radius:2px;transform:translateX(-50%);box-shadow:0 0 0 2px #fff}\n  .bandscale{display:flex;justify-content:space-between;font-size:9px;color:var(--faint);margin-bottom:10px}\n  .sc-sub{font-size:11.5px;color:var(--muted);line-height:1.45}\n  .sc-meth{font-size:10.5px;color:var(--faint);margin-top:7px}\n</style>\n<script>\n(function(){\n  const pts = {critical:12, high:5, medium:2, low:0.25};\n  const sevRank = {critical:4, high:3, medium:2, low:1};\n  const anchorMap = {4:75, 3:50, 2:28, 1:12, 0:0};\n  const SURFLAB = {code_repo:'code', cicd:'CI/CD', hf_org_api:'HF org API', huggingface_org:'HF org API'};\n  const CATLAB = {pii:'PII', phi:'PHI', credentials:'credentials', internal_data:'internal data', financial:'financial'};\n  function compute(model){\n    const scan = (model && model.data_scan_results) || {};\n    const report = (model && model.data) || {};\n    const cr = scan.crossings || {};\n    const byProv = (scan.components && scan.components.summary && scan.components.summary.by_provider) || {};\n    const byType = (scan.components && scan.components.summary && scan.components.summary.by_type) || {};\n    const findings = report.findings || [];\n    const crit = cr.critical_count || 0;\n    const high = cr.high_count || 0;\n    const med  = cr.medium_count || 0;\n    const pickle = byProv.Pickle || 0;\n    const pulls = findings.filter(f => f.category === 'hf_import').length || 0;\n    const buckets = [\n      {sev:'critical', n:crit},{sev:'high', n:high},{sev:'high', n:pickle},\n      {sev:'medium', n:med},{sev:'low', n:pulls}\n    ].filter(b => b.n > 0);\n    let raw = 0, worst = 0;\n    buckets.forEach(b=>{ raw += pts[b.sev]*Math.min(1+Math.log(b.n),5); worst = Math.max(worst, sevRank[b.sev]); });\n    const volume = 25*(1-Math.exp(-raw/30));\n    const score = Math.round(Math.min(100,(anchorMap[worst]||0)+volume));\n    const reposScanned = report.repos_scanned || (Array.isArray(report.repo) ? report.repo.length : 0);\n    const reposAI = (report.inventory && report.inventory.repos_using_ai || []).length;\n    const crossings = cr.total_crossings || 0;\n    const artifacts = (byType.model_artifact && byType.model_artifact.count) || 0;\n    const scanId = (report.scan_name || '').slice(0,8);\n    const surfaces = (report.surfaces_run || []).map(s=> SURFLAB[s]||s).join(' + ');\n    // describe the lead criticals dynamically (crossings critical leads)\n    const critCross = (cr.crossings || []).filter(c=>c.severity==='critical');\n    const cats = [...new Set(critCross.map(c=>c.data_category))].map(c=>CATLAB[c]||c);\n    const allProhibited = critCross.length>0 && critCross.every(c=>c.ai_eligibility==='prohibited');\n    let critPhrase;\n    if(cats.length){\n      const catsTxt = cats.length===1 ? cats[0] : cats.slice(0,-1).join(', ')+' and '+cats.slice(-1);\n      critPhrase = `${catsTxt} reaching AI boundaries${allProhibited?' (all prohibited)':''}`;\n    } else {\n      critPhrase = 'sensitive values reaching AI boundaries';\n    }\n    const critSub = crit\n      ? `${crit} critical data→AI crossing${crit===1?'':'s'}${allProhibited?', all prohibited':''}`\n      : 'no critical crossings';\n    return {score, band:band(score), bandColor:bandColor(score),\n      reposScanned, reposAI, pulls, crossings, crit, artifacts, pickle,\n      scanId, surfaces, critPhrase, critSub};\n  }\n  function band(s){ return s<=20?'Low':s<=45?'Moderate':s<=70?'Elevated':s<=90?'High':'Critical'; }\n  function bandColor(s){ return s<=20?'var(--b-low)':s<=45?'var(--b-mod)':s<=70?'var(--b-elev)':s<=90?'var(--b-high)':'var(--b-crit)'; }\n  function render(model){\n    const d = compute(model);\n    const hasData = d.reposScanned || d.crossings || d.pulls;\n    if(!hasData){\n      document.getElementById('root').innerHTML = '<div class=\"aue-loading\">Waiting for scan data…</div>';\n      return;\n    }\n    const segs = [\n      {w:20,c:'var(--b-low)'},{w:25,c:'var(--b-mod)'},{w:25,c:'var(--b-elev)'},\n      {w:20,c:'var(--b-high)'},{w:10,c:'var(--b-crit)'}\n    ].map(s=>`<div class=\"seg\" style=\"width:${s.w}%;background:${s.c}\"></div>`).join('');\n    document.getElementById('root').innerHTML = `\n      <div class=\"aue-wrap\">\n        <div class=\"aue-pagetitle\">Shadow AI Code Scanner</div>\n        <div class=\"aue-top\">\n          <div>\n            <div class=\"aue-title\">AI Usage &amp; Exposure</div>\n            <div class=\"aue-prov\">\n              <span class=\"chip\">scan <b>${d.scanId||'—'}</b></span>\n              <span class=\"chip\">source <b>github</b></span>\n              <span class=\"chip\"><b>${d.reposScanned}</b> repos</span>\n              <span class=\"chip\">surfaces <b>${d.surfaces||'—'}</b></span>\n            </div>\n          </div>\n          <div class=\"phases\">\n            <span class=\"ph\"><span class=\"dot\"></span>Discovery <small>done</small></span>\n            <span class=\"arrow\">→</span>\n            <span class=\"ph\"><span class=\"dot\"></span>Posture <small>done</small></span>\n          </div>\n        </div>\n        <div class=\"aue-sub\">One scan, two phases — <b>Discovery</b> finds where AI is used; <b>Posture</b> scores how risky that use is. Discovery never emits a score; Posture does.</div>\n        <div class=\"aue-main\">\n          <div class=\"aue-headline\">\n            AI found in <span class=\"n\">${d.reposAI} of ${d.reposScanned}</span> repos\n            (<span class=\"n\">${d.pulls}</span> model pulls).\n            <span class=\"n\">${d.crossings}</span> flows carry sensitive data into AI boundaries —\n            <span class=\"crit\">${d.crit} critical</span>: ${d.critPhrase}.\n            <span class=\"n\">${d.artifacts}</span> model artifacts ship in code-executing formats\n            (<span class=\"warn\">${d.pickle} unsigned</span>); <span class=\"n\">${d.pulls}</span> pulls are unpinned.\n          </div>\n          <div class=\"scorecard\">\n            <div class=\"sc-label\">Posture Score</div>\n            <div class=\"sc-num\"><span style=\"color:${d.bandColor}\">${d.score}</span><small>/ 100</small></div>\n            <div class=\"sc-band\" style=\"background:${d.bandColor}\">${d.band}</div>\n            <div class=\"bandbar\">\n              ${segs}\n              <div class=\"marker\" style=\"left:${d.score}%\"></div>\n            </div>\n            <div class=\"bandscale\"><span>0</span><span>20</span><span>45</span><span>70</span><span>90</span><span>100</span></div>\n            <div class=\"sc-sub\">Severity-weighted · anchored by the worst finding (${d.critSub}).</div>\n            <div class=\"sc-meth\">Full formula in the methodology card at the bottom of the dashboard.</div>\n          </div>\n        </div>\n      </div>`;\n  }\n  function boot(){\n    if (typeof appsmith === 'undefined'){ setTimeout(boot, 50); return; }\n    appsmith.onReady(function(){ render(appsmith.model); });\n    if (appsmith.onModelChange) appsmith.onModelChange(function(m){ render(m); });\n  }\n  boot();\n})();\n</script>",
    "js": ""
  },
