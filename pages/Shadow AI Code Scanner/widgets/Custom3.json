    "css": "",
    "html": "<div id=\"root\"><div class=\"ld\">Waiting for scan data…</div></div>\n<style>\n  :root{\n    --ink:#0f172a;--muted:#64748b;--faint:#94a3b8;--line:#e8edf3;\n    --panel:#fff;--soft:#f8fafc;--accent:#4f46e5;\n    --crit:#dc2626;--high:#ea580c;--med:#d97706;--low:#2563eb;\n    --cred:#dc2626;--pii:#ea580c;--phi:#db2777;--intl:#6366f1;--fin:#d97706;\n    --bprompt:#4f46e5;--bembed:#0891b2;--brag:#7c3aed;\n    --sans:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;\n    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;background:transparent;font-family:var(--sans);color:var(--ink)}\n  .ld{padding:28px;color:var(--faint);font-size:13px}\n  .wrap{background:var(--panel);border:1px solid var(--line);border-radius:14px;\n    padding:20px 22px;box-shadow:0 1px 2px rgba(15,23,42,.04)}\n  .acthead{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:4px}\n  .actname{font-size:18px;font-weight:700;letter-spacing:-.01em}\n  .actsub{font-size:12.5px;color:var(--muted);line-height:1.5;margin:6px 0 18px;\n    padding-left:11px;border-left:3px solid var(--crit)}\n  .actsub b{color:var(--ink)}\n  .ptitle{font-size:13px;font-weight:700;margin-bottom:2px}\n  .ptitle .star{color:var(--crit);font-size:11px;font-weight:700;margin-left:6px;letter-spacing:.04em}\n  .pcap{font-size:11px;color:var(--faint);margin-bottom:12px}\n  .pblock{margin-bottom:24px}\n  .p6top{display:grid;grid-template-columns:1.1fr 1fr 1fr;gap:14px;margin-bottom:16px}\n  @media(max-width:760px){.p6top{grid-template-columns:1fr}}\n  .card{border:1px solid var(--line);border-radius:11px;padding:13px 15px;background:var(--soft)}\n  .card .ch{font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--faint);font-weight:700;margin-bottom:10px}\n  .sevline{display:flex;align-items:center;gap:7px;margin:7px 0}\n  .sevdot{width:9px;height:9px;border-radius:50%}\n  .sevline .lab{font-size:12px;color:var(--ink);flex:1}\n  .sevline .n{font-size:13px;font-weight:800}\n  .donutwrap{display:flex;align-items:center;gap:14px}\n  .legend{font-size:11px;line-height:1.7}\n  .legend i{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px;vertical-align:middle}\n  .legend b{font-weight:700}\n  .xr{border:1px solid var(--line);border-radius:11px;padding:13px 15px;margin:8px 0;background:#fff}\n  .xr.critrow{border-color:#fecaca;background:linear-gradient(180deg,#fff,#fef2f2)}\n  .xr-main{display:flex;align-items:center;gap:12px;flex-wrap:wrap}\n  .sev{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;\n    color:#fff;border-radius:5px;padding:3px 8px;flex:0 0 auto}\n  .flow{font-size:13px;flex:1 1 300px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}\n  .catchip{font-weight:700;font-family:var(--mono);font-size:12px}\n  .arrow{color:var(--faint)}\n  .bnd{font-family:var(--mono);font-size:12px;color:var(--ink);background:#f1f5f9;border-radius:5px;padding:2px 7px}\n  .styp{font-size:11px;color:var(--muted)}\n  .elig{font-size:10px;font-weight:700;text-transform:uppercase;border-radius:5px;padding:2px 7px}\n  .elig.prohibited{color:#fff;background:var(--crit)}\n  .elig.restricted{color:var(--high);background:#fff7ed;border:1px solid #fed7aa}\n  .loc{font-family:var(--mono);font-size:11.5px;color:var(--muted);flex:0 0 auto}\n  .rec{font-size:11.5px;color:var(--muted);margin-top:8px;line-height:1.45;padding-left:2px}\n  .rec b{color:var(--crit)}\n  .morerow{border:1px dashed var(--line);border-radius:11px;padding:11px 15px;margin:8px 0;background:var(--soft);\n    font-size:12px;color:var(--muted);text-align:center}\n  .morerow b{color:var(--ink)}\n  .sc-top{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px}\n  .scstat{flex:1 1 150px;border:1px solid var(--line);border-radius:11px;padding:13px 15px;background:var(--soft)}\n  .scstat .v{font-size:24px;font-weight:800;line-height:1}\n  .scstat .l{font-size:11px;color:var(--muted);margin-top:5px}\n  .scstat.alert{background:#fef2f2;border-color:#fecaca}\n  .scstat.alert .v{color:var(--crit)}\n  table{width:100%;border-collapse:collapse}\n  thead th{font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);\n    font-weight:700;text-align:left;padding:8px 10px;border-bottom:1px solid var(--line)}\n  thead th.r,tbody td.r{text-align:right}\n  tbody td{padding:11px 10px;border-bottom:1px solid var(--line);font-size:12.5px}\n  tbody tr:last-child td{border-bottom:none}\n  .fmt{font-family:var(--mono);font-weight:600}\n  .tag{font-size:10px;font-weight:700;border-radius:5px;padding:2px 8px;display:inline-block}\n  .tag.bad{color:#fff;background:var(--crit)}\n  .tag.std{color:#475569;background:#f1f5f9;border:1px solid var(--line)}\n  .tag.warn{color:var(--med);background:#fffbeb;border:1px solid #fcd34d}\n  /* taint panel */\n  .taint{border:1px solid var(--line);border-radius:12px;padding:16px 18px;background:var(--soft)}\n  .taint.disabled{border-style:dashed;background:#fff}\n  .taint-grid{display:grid;grid-template-columns:auto auto 1fr;gap:18px;align-items:center}\n  @media(max-width:680px){.taint-grid{grid-template-columns:1fr}}\n  .tnum{font-size:30px;font-weight:800;line-height:1}\n  .tnum.muted{color:var(--faint)}\n  .tnum small{font-size:11px;color:var(--faint);font-weight:700;text-transform:uppercase;display:block;margin-top:4px;letter-spacing:.04em}\n  .vline{width:1px;align-self:stretch;background:var(--line)}\n  .engines{display:flex;flex-direction:column;gap:8px}\n  .eng{display:flex;align-items:center;gap:9px;font-size:12.5px}\n  .eng .b{font-size:11px;font-weight:800;border-radius:5px;padding:2px 8px;color:#fff}\n  .eng .off{background:var(--faint)} .eng .on{background:var(--crit)}\n  .eng .txt{color:var(--muted)} .eng .txt b{color:var(--ink)}\n  .tnote{font-size:11.5px;color:var(--muted);line-height:1.5;margin-top:12px;padding-top:12px;border-top:1px dashed #d8e0ea}\n  .tnote b{color:var(--ink)}\n  .disabled-badge{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;\n    color:var(--muted);background:var(--soft);border:1px solid var(--line);border-radius:5px;padding:2px 8px;margin-left:8px}\n</style>\n<script>\n(function(){\n  const SEVC={critical:'var(--crit)',high:'var(--high)',medium:'var(--med)',low:'var(--low)'};\n  const CATC={credentials:'var(--cred)',pii:'var(--pii)',phi:'var(--phi)',internal_data:'var(--intl)',financial:'var(--fin)'};\n  const BNDC={llm_prompt:'var(--bprompt)',embedding:'var(--bembed)',rag_index:'var(--brag)'};\n  const BLAB={llm_prompt:'LLM prompt',embedding:'Embedding',rag_index:'RAG index'};\n  const order={critical:0,high:1,medium:2,low:3};\n  const CAP=16;\n\n  function donut(segs,size){\n    const r=size/2-7, c=2*Math.PI*r, cx=size/2, total=segs.reduce((s,x)=>s+x.v,0)||1;\n    let off=0, arcs='';\n    segs.forEach(s=>{\n      const len=s.v/total*c;\n      arcs+=`<circle cx=\"${cx}\" cy=\"${cx}\" r=\"${r}\" fill=\"none\" stroke=\"${s.c}\" stroke-width=\"11\"\n        stroke-dasharray=\"${len} ${c-len}\" stroke-dashoffset=\"${-off}\" transform=\"rotate(-90 ${cx} ${cx})\"/>`;\n      off+=len;\n    });\n    return `<svg width=\"${size}\" height=\"${size}\" viewBox=\"0 0 ${size} ${size}\">\n      <circle cx=\"${cx}\" cy=\"${cx}\" r=\"${r}\" fill=\"none\" stroke=\"#eef1f6\" stroke-width=\"11\"/>${arcs}\n      <text x=\"${cx}\" y=\"${cx+1}\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"15\" font-weight=\"800\" fill=\"#0f172a\">${total}</text>\n    </svg>`;\n  }\n\n  function render(model){\n    const scan=(model&&model.data_scan_results)||{};\n    const report=(model&&model.data)||{};\n    const cr=scan.crossings||{};\n    const all=(cr.crossings||[]).slice().sort((a,b)=>(order[a.severity]??9)-(order[b.severity]??9));\n    const byCat=cr.by_category||{};\n    const bb=scan.crossings&&scan.crossings.by_boundary||{};\n    const bndTotals={}; Object.keys(bb).forEach(k=>bndTotals[k]=Object.values(bb[k]).reduce((s,n)=>s+n,0));\n    const mart=(scan.components&&scan.components.summary&&scan.components.summary.by_type&&scan.components.summary.by_type.model_artifact)||{count:0,providers:{}};\n    const pickle=(mart.providers&&mart.providers.Pickle||[]).length;\n    const pytorch=(mart.providers&&mart.providers.PyTorch||[]).length;\n    const pulls=(report.findings||[]).filter(f=>f.category==='hf_import').length;\n    const cf=scan.cross_file||{};\n    const taintDisabled = cf.status==='skipped' || cf.status==='disabled';\n    const tainted=cf.tainted_symbols||0, bounds=cf.ai_boundaries||0, confirmedPaths=(cf.tainted_to_ai||[]).length;\n    const total=cr.total_crossings||all.length;\n\n    if(!all.length && !mart.count){\n      document.getElementById('root').innerHTML='<div class=\"ld\">Waiting for scan data…</div>';return;}\n\n    const sevSum=[['critical',cr.critical_count||0],['high',cr.high_count||0],['medium',cr.medium_count||0],['low',cr.low_count||0]]\n      .filter(x=>x[1]>0).map(([s,n])=>`<div class=\"sevline\"><span class=\"sevdot\" style=\"background:${SEVC[s]}\"></span><span class=\"lab\" style=\"text-transform:capitalize\">${s}</span><span class=\"n\" style=\"color:${SEVC[s]}\">${n}</span></div>`).join('');\n    const catSegs=Object.keys(byCat).map(k=>({v:byCat[k],c:getComputedColor(CATC[k]||'#94a3b8')}));\n    const catLegend=Object.keys(byCat).sort((a,b)=>byCat[b]-byCat[a]).map(k=>`<div><i style=\"background:${getComputedColor(CATC[k]||'#94a3b8')}\"></i>${k.replace('_',' ')} <b>${byCat[k]}</b></div>`).join('');\n    const bndSegs=Object.keys(bndTotals).map(k=>({v:bndTotals[k],c:getComputedColor(BNDC[k]||'#94a3b8')}));\n    const bndLegend=Object.keys(bndTotals).sort((a,b)=>bndTotals[b]-bndTotals[a]).map(k=>`<div><i style=\"background:${getComputedColor(BNDC[k]||'#94a3b8')}\"></i>${BLAB[k]||k} <b>${bndTotals[k]}</b></div>`).join('');\n\nconst shown=all;\n    const rows=shown.map(c=>{\n      const isCrit=c.severity==='critical';\n      return `<div class=\"xr ${isCrit?'critrow':''}\">\n        <div class=\"xr-main\">\n          <span class=\"sev\" style=\"background:${SEVC[c.severity]||'#64748b'}\">${c.severity}</span>\n          <div class=\"flow\">\n            <span class=\"catchip\" style=\"color:${getComputedColor(CATC[c.data_category]||'#0f172a')}\">${(c.data_category||'').replace('_',' ')}</span>\n            <span class=\"styp\">${c.sensitive_data_type||''}</span>\n            <span class=\"arrow\">→</span>\n            <span class=\"bnd\">${BLAB[c.boundary_type]||c.boundary_type}</span>\n            <span class=\"elig ${c.ai_eligibility}\">${c.ai_eligibility}</span>\n          </div>\n          <span class=\"loc\">${(c.file||'').split('/').pop()}:${c.line}</span>\n        </div>\n        ${c.recommendation?`<div class=\"rec\">${isCrit?'<b>CRITICAL — </b>':''}${c.recommendation}</div>`:''}\n      </div>`;}).join('');\nconst moreRow = '';\n    // taint panel — disabled vs run\n    let taintPanel;\n    if(taintDisabled){\n      taintPanel=`<div class=\"taint disabled\">\n        <div class=\"taint-grid\">\n          <div><div class=\"tnum muted\">—</div><small>stage disabled</small></div>\n          <div class=\"vline\"></div>\n          <div class=\"engines\">\n            <div class=\"eng\"><span class=\"b on\">${total}</span><span class=\"txt\">confirmed crossings via the <b>boundary-crossing engine</b> (shown above)</span></div>\n            <div class=\"eng\"><span class=\"b off\">off</span><span class=\"txt\"><b>cross-file taint engine</b> was disabled in this scan (<span class=\"mono\">${cf.reason||'stage disabled'}</span>)</span></div>\n          </div>\n        </div>\n        <div class=\"tnote\"><b>The cross-file taint stage did not run this scan.</b> The ${total} crossings above come from the independent boundary-crossing engine and stand on their own. Re-enable the taint stage to add whole-program symbol tracing (the larger candidate surface) on top of these confirmed findings.</div>\n      </div>`;\n    } else {\n      taintPanel=`<div class=\"taint\">\n        <div class=\"taint-grid\">\n          <div><div class=\"tnum\">${tainted.toLocaleString()}</div><small>symbols analyzed</small></div>\n          <div class=\"vline\"></div>\n          <div class=\"engines\">\n            <div class=\"eng\"><span class=\"b off\">${confirmedPaths}</span><span class=\"txt\">confirmed paths via the <b>cross-file taint engine</b> (${bounds} AI boundaries reached)</span></div>\n            <div class=\"eng\"><span class=\"b on\">${total}</span><span class=\"txt\">confirmed crossings via the <b>boundary-crossing engine</b> (shown above)</span></div>\n          </div>\n        </div>\n        <div class=\"tnote\"><b>${tainted.toLocaleString()} is the surface analyzed, not the exposure.</b> Only the ${total} confirmed crossings carry severity and feed the Posture Score — the large symbol count is coverage, not risk.</div>\n      </div>`;\n    }\n\n    document.getElementById('root').innerHTML=`\n    <div class=\"wrap\">\n      <div class=\"acthead\"><span class=\"actname\">Risk</span></div>\n      <div class=\"actsub\"><b>How risky the discovered AI usage actually is.</b> Two things that other scanners miss: sensitive data crossing into AI boundaries, and model-artifact supply-chain integrity. This is the phase that assigns severity and drives the Posture Score.</div>\n\n      <div class=\"pblock\">\n        <div class=\"ptitle\">Sensitive data → AI crossings <span class=\"star\">★ DIFFERENTIATOR</span></div>\n        <div class=\"pcap\">Flows where restricted or prohibited data reaches an AI boundary · ${total} found</div>\n        <div class=\"p6top\">\n          <div class=\"card\"><div class=\"ch\">By severity</div>${sevSum}</div>\n          <div class=\"card\"><div class=\"ch\">By data category</div><div class=\"donutwrap\">${donut(catSegs,92)}<div class=\"legend\">${catLegend}</div></div></div>\n          <div class=\"card\"><div class=\"ch\">By AI boundary</div><div class=\"donutwrap\">${donut(bndSegs,92)}<div class=\"legend\">${bndLegend}</div></div></div>\n        </div>\n        ${rows}\n        ${moreRow}\n      </div>\n\n      <div class=\"pblock\">\n        <div class=\"ptitle\">Supply-chain integrity</div>\n        <div class=\"pcap\">Model artifacts and how they load — serialization formats that execute code are the risk</div>\n        <div class=\"sc-top\">\n          <div class=\"scstat\"><div class=\"v\">${mart.count}</div><div class=\"l\">Model artifacts</div></div>\n          <div class=\"scstat alert\"><div class=\"v\">${pickle}</div><div class=\"l\">Unsigned Pickle (executes on load)</div></div>\n          <div class=\"scstat\"><div class=\"v\">${pulls}</div><div class=\"l\">Unpinned <code>from_pretrained</code> pulls</div></div>\n        </div>\n        <table>\n          <thead><tr><th>Format</th><th class=\"r\">Count</th><th>Integrity</th><th>Risk</th></tr></thead>\n          <tbody>\n            <tr><td class=\"fmt\">Pickle (.pkl)</td><td class=\"r\">${pickle}</td><td>Unsigned · arbitrary code on deserialize</td><td><span class=\"tag bad\">High exposure</span></td></tr>\n            <tr><td class=\"fmt\">PyTorch (.pth)</td><td class=\"r\">${pytorch}</td><td>Standard tooling · also pickle-backed</td><td><span class=\"tag std\">Standard</span></td></tr>\n            <tr><td class=\"fmt\">from_pretrained</td><td class=\"r\">${pulls}</td><td>Unpinned revisions · source can shift</td><td><span class=\"tag warn\">Hygiene</span></td></tr>\n          </tbody>\n        </table>\n      </div>\n\n      <div class=\"pblock\" style=\"margin-bottom:0\">\n        <div class=\"ptitle\">Tainted symbol surface ${taintDisabled?'<span class=\"disabled-badge\">stage disabled</span>':''}</div>\n        <div class=\"pcap\">Whole-program taint tracing — separate from the confirmed crossings above</div>\n        ${taintPanel}\n      </div>\n    </div>`;\n  }\n  function getComputedColor(v){\n    if(v && v.indexOf('var(')===0){\n      const name=v.slice(4,-1).trim();\n      const val=getComputedStyle(document.documentElement).getPropertyValue(name).trim();\n      return val||'#94a3b8';\n    }\n    return v;\n  }\n  function boot(){\n    if(typeof appsmith==='undefined'){setTimeout(boot,50);return;}\n    appsmith.onReady(function(){render(appsmith.model);});\n    if(appsmith.onModelChange) appsmith.onModelChange(function(m){render(m);});\n  }\n  boot();\n})();\n</script>",
    "js": ""
  },
  "version": 1,
  "widgetId": "mslzaynmg1",
  "widgetName": "Custom3"
}